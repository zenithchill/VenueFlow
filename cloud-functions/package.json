{
  "name": "venueflow-cloud-functions",
  "version": "2.0.0",
  "description": "VenueFlow serverless backend: BigQuery sync, Vertex AI Gemini Pro crowd predictions, Cloud NLP sentiment, Pub/Sub streaming",
  "main": "index.js",
  "engines": { "node": "20" },
  "scripts": {
    "serve":  "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "lint":   "eslint .",
    "test":   "jest"
  },
  "dependencies": {
    "firebase-admin":            "^12.1.0",
    "firebase-functions":        "^5.0.0",
    "@google-cloud/bigquery":    "^7.7.0",
    "@google-cloud/vertexai":    "^1.1.0",
    "@google-cloud/language":    "^6.0.2",
    "@google-cloud/pubsub":      "^4.5.0",
    "@google-cloud/storage":     "^7.10.0"
  },
  "devDependencies": {
    "eslint":               "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "jest":                 "^29.7.0"
  },
  "keywords": [
    "venueflow","bigquery","vertex-ai","gemini","cloud-functions",
    "cloud-nlp","pubsub","firebase","crowd-management","stadium"
  ],
  "private": true
}
